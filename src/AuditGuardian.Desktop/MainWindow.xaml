<Window x:Class="AuditGuardian.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="赛审卫士 · 反作弊与行为审计系统"
        Width="1360" Height="860" MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrBg}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="Microsoft YaHei, Segoe UI, sans-serif"
        FontSize="13"
        SnapsToDevicePixels="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ SIDEBAR ============ -->
        <Border Grid.Column="0" Background="{StaticResource BrSidebar}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="62"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1">
                    <Grid Margin="18,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                Background="{StaticResource BrAccent}" Margin="0,0,12,0">
                            <TextBlock Text="🛡" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="赛审卫士" FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrTextPrimary}"/>
                            <TextBlock Text="反作弊审计系统" FontSize="10" Foreground="{StaticResource BrTextMuted}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="10,14,10,0">
                    <Border Name="NavDashboard" Style="{StaticResource NavItem}" Background="{StaticResource BrAccentBg}"
                            MouseDown="Nav_Click" Tag="Dashboard">
                        <Grid Margin="14,0">
                            <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="仪表盘" FontSize="13" Margin="28,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource BrAccent}" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                    <Border Name="NavHardware" Style="{StaticResource NavItem}" MouseDown="Nav_Click" Tag="Hardware">
                        <Grid Margin="14,0">
                            <TextBlock Text="🖥" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="硬件信息" FontSize="13" Margin="28,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource BrTextSecondary}"/>
                        </Grid>
                    </Border>
                    <Border Name="NavTimeline" Style="{StaticResource NavItem}" MouseDown="Nav_Click" Tag="Timeline">
                        <Grid Margin="14,0">
                            <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="行为时间线" FontSize="13" Margin="28,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource BrTextSecondary}"/>
                        </Grid>
                    </Border>
                    <Border Name="NavScan" Style="{StaticResource NavItem}" MouseDown="Nav_Click" Tag="Scan">
                        <Grid Margin="14,0">
                            <TextBlock Text="🔬" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="反作弊扫描" FontSize="13" Margin="28,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource BrTextSecondary}"/>
                        </Grid>
                    </Border>
                    <Border Name="NavReport" Style="{StaticResource NavItem}" MouseDown="Nav_Click" Tag="Report">
                        <Grid Margin="14,0">
                            <TextBlock Text="📑" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="报告管理" FontSize="13" Margin="28,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource BrTextSecondary}"/>
                        </Grid>
                    </Border>
                    <Border Height="1" Background="{StaticResource BrBorder}" Margin="14,4"/>
                    <Border Name="NavSettings" Style="{StaticResource NavItem}" MouseDown="Nav_Click" Tag="Settings">
                        <Grid Margin="14,0">
                            <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="设置" FontSize="13" Margin="28,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource BrTextSecondary}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <Border Grid.Row="2" BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0" Padding="16,12">
                    <Grid>
                        <Ellipse Width="7" Height="7" Fill="{StaticResource BrGreen}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="本机采集端" FontSize="11" Foreground="{StaticResource BrTextMuted}" Margin="14,0,0,0"/>
                        <TextBlock Text="v1.0.0" FontSize="10" Foreground="{StaticResource BrTextMuted}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ============ MAIN CONTENT ============ -->
        <Grid Grid.Column="1" Background="{StaticResource BrBg}">
            <ScrollViewer x:Name="MainScroll" VerticalScrollBarVisibility="Auto" Padding="32,28">
                <StackPanel>

                    <!-- ===== DASHBOARD ===== -->
                    <StackPanel Name="PanelDashboard">
                        <TextBlock Text="仪表盘" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="系统概览与快捷操作" FontSize="13" Foreground="{StaticResource BrTextSecondary}" Margin="0,4,0,24"/>

                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBase}" Margin="5,0" Padding="20">
                                <StackPanel>
                                    <Grid><TextBlock Text="硬件状态" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/><Ellipse Width="8" Height="8" Fill="{StaticResource BrGreen}" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    <TextBlock x:Name="DashHardwareVal" Text="-" Style="{StaticResource StatValue}" Margin="0,14,0,2"/>
                                    <TextBlock x:Name="DashHardwareDesc" Text="点击按钮采集" Style="{StaticResource StatLabel}"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="📥 采集" Margin="0,12,0,0" Height="32" FontSize="11" Click="LoadHardware_Click"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBase}" Margin="5,0" Padding="20">
                                <StackPanel>
                                    <Grid><TextBlock Text="事件日志" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/><Ellipse Width="8" Height="8" Fill="{StaticResource BrBlue}" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    <TextBlock x:Name="DashEventVal" Text="-" Style="{StaticResource StatValue}" Margin="0,14,0,2"/>
                                    <TextBlock x:Name="DashEventDesc" Text="点击按钮加载" Style="{StaticResource StatLabel}"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="📥 加载" Margin="0,12,0,0" Height="32" FontSize="11" Click="LoadEvents_Click"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardBase}" Margin="5,0" Padding="20">
                                <StackPanel>
                                    <Grid><TextBlock Text="风险项" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/><Ellipse Width="8" Height="8" Fill="{StaticResource BrYellow}" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    <TextBlock x:Name="DashRiskVal" Text="-" Style="{StaticResource StatValue}" Foreground="{StaticResource BrYellow}" Margin="0,14,0,2"/>
                                    <TextBlock x:Name="DashRiskDesc" Text="点击按钮扫描" Style="{StaticResource StatLabel}"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="🔬 扫描" Margin="0,12,0,0" Height="32" FontSize="11" Click="LoadScan_Click"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource CardBase}" Margin="5,0" Padding="20">
                                <StackPanel>
                                    <Grid><TextBlock Text="报告状态" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/><Ellipse Width="8" Height="8" Fill="{StaticResource BrTextMuted}" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    <TextBlock x:Name="DashReportVal" Text="未生成" Style="{StaticResource StatValue}" Foreground="{StaticResource BrTextMuted}" Margin="0,14,0,2"/>
                                    <TextBlock Text="生成后上传审核" Style="{StaticResource StatLabel}"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="📄 生成" Margin="0,12,0,0" Height="32" FontSize="11" Click="GenerateReport_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Risk Items (from real scan data) -->
                        <Border Name="DashboardRiskPanel" Style="{StaticResource CardBase}" Padding="20"
                                Margin="0,0,0,24" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="⚠ 最近风险项" Style="{StaticResource SectionTitle}"/>
                                <ItemsControl Name="DashboardRiskContainer">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource BrInputBg}" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                                <Grid>
                                                    <Ellipse Width="7" Height="7" Fill="{Binding SeverityColor}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="13" Margin="16,0,0,0" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ===== HARDWARE ===== -->
                    <StackPanel Name="PanelHardware" Visibility="Collapsed">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="硬件信息" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="硬件指纹采集与篡改检测" FontSize="13" Foreground="{StaticResource BrTextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="📥 采集硬件数据" Click="LoadHardware_Click" Height="38"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox Name="HardwareSearchBox" Style="{StaticResource InputField}" TextChanged="HardwareSearch_TextChanged"
                                     Text="" FontSize="12" Padding="10,6"/>
                            <TextBlock Name="HardwareCountText" Text="-" FontSize="11" Foreground="{StaticResource BrTextSecondary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>

                        <Border Name="SpoofAlert" Style="{StaticResource CardBase}" Padding="14,12" Margin="0,0,0,16"
                                BorderBrush="{StaticResource BrYellow}" Background="#FBBF2408" Visibility="Collapsed">
                            <Grid><TextBlock Text="⚠" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Name="SpoofAlertText" Text="" Margin="24,0,0,0" Foreground="{StaticResource BrYellow}" FontSize="13"/></Grid>
                        </Border>

                        <ItemsControl Name="HardwareItemsContainer">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBase}" Margin="4" Padding="18" Width="380">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{Binding StatusColor}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Properties}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" Foreground="{StaticResource BrTextSecondary}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" HorizontalAlignment="Right" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ===== TIMELINE ===== -->
                    <StackPanel Name="PanelTimeline" Visibility="Collapsed">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="行为时间线" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="用户操作完整回溯" FontSize="13" Foreground="{StaticResource BrTextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="📥 加载事件日志" Click="LoadEvents_Click" Height="38"/>
                        </Grid>

                        <TextBox Name="TimelineSearchBox" Style="{StaticResource InputField}" TextChanged="TimelineSearch_TextChanged"
                                 Text="" FontSize="12" Padding="10,6" Margin="0,0,0,12"/>
                        <TextBlock Name="TimelineNote" Text="" FontSize="11" Foreground="{StaticResource BrTextSecondary}" Margin="0,-6,0,10"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBase}" Padding="14,12" Margin="3">
                                <StackPanel><TextBlock Name="TimelineTotalEvents" Text="0" Style="{StaticResource StatValue}" FontSize="20"/><TextBlock Text="总事件数" Style="{StaticResource StatLabel}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBase}" Padding="14,12" Margin="3">
                                <StackPanel><TextBlock Name="TimelineProcesses" Text="0" Style="{StaticResource StatValue}" FontSize="20"/><TextBlock Text="进程活动" Style="{StaticResource StatLabel}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardBase}" Padding="14,12" Margin="3">
                                <StackPanel><TextBlock Name="TimelineFiles" Text="0" Style="{StaticResource StatValue}" FontSize="20"/><TextBlock Text="文件操作" Style="{StaticResource StatLabel}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource CardBase}" Padding="14,12" Margin="3">
                                <StackPanel><TextBlock Name="TimelineUsb" Text="0" Style="{StaticResource StatValue}" FontSize="20"/><TextBlock Text="USB事件" Style="{StaticResource StatLabel}"/></StackPanel>
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource CardBase}" Padding="14,12" Margin="3">
                                <StackPanel><TextBlock Name="TimelineSystem" Text="0" Style="{StaticResource StatValue}" FontSize="20"/><TextBlock Text="系统变更" Style="{StaticResource StatLabel}"/></StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource CardBase}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="事件日志" Style="{StaticResource SectionTitle}"/>
                                <ItemsControl Name="EventLogContainer" MaxHeight="600">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource EventItem}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Ellipse Width="7" Height="7" Fill="{Binding SeverityColor}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="13" Margin="16,0,0,0" TextWrapping="Wrap"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{StaticResource BrTextMuted}" Margin="16,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ===== SCAN ===== -->
                    <StackPanel Name="PanelScan" Visibility="Collapsed">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="反作弊扫描" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="检测作弊程序、内核Hook与系统异常" FontSize="13" Foreground="{StaticResource BrTextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="🛡 启动深度扫描" Click="StartScan_Click"/>
                        </Grid>

                        <TextBox Name="ScanSearchBox" Style="{StaticResource InputField}" TextChanged="ScanSearch_TextChanged"
                                 Text="" FontSize="12" Padding="10,6" Margin="0,0,0,12"/>
                        <TextBlock Name="ScanNote" Text="" FontSize="11" Foreground="{StaticResource BrTextSecondary}" Margin="0,-6,0,10"/>

                        <Border Name="ScanProgressPanel" Style="{StaticResource CardBase}" Padding="20" Margin="0,0,0,20" Visibility="Collapsed">
                            <StackPanel>
                                <Grid><TextBlock Name="ScanProgressText" Text="准备扫描..." FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Name="ScanProgressPercent" Text="0%" FontSize="12" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Right"/></Grid>
                                <Border Height="6" Background="{StaticResource BrInputBg}" CornerRadius="999" Margin="0,10,0,0">
                                    <Border Name="ScanProgressFill" Height="6" Background="{StaticResource BrAccent}" CornerRadius="999" HorizontalAlignment="Left" Width="0"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Name="ScanResultsPanel" Style="{StaticResource CardBase}" Padding="20" Margin="0,0,0,20" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource BrInputBg}" CornerRadius="12" Padding="18" Margin="0,0,28,0">
                                    <StackPanel><TextBlock Text="🛡" FontSize="30" HorizontalAlignment="Center"/>
                                        <TextBlock Name="ScanTotalFindings" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrRed}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        <TextBlock Text="风险项" FontSize="11" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                </Border>
                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel HorizontalAlignment="Center"><TextBlock Name="ScanCriticalCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrRed}" HorizontalAlignment="Center"/><TextBlock Text="严重" FontSize="11" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                    <StackPanel HorizontalAlignment="Center"><TextBlock Name="ScanHighCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrRed}" HorizontalAlignment="Center"/><TextBlock Text="高危" FontSize="11" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                    <StackPanel HorizontalAlignment="Center"><TextBlock Name="ScanMediumCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrYellow}" HorizontalAlignment="Center"/><TextBlock Text="可疑" FontSize="11" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                    <StackPanel HorizontalAlignment="Center"><TextBlock Name="ScanPassCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrGreen}" HorizontalAlignment="Center"/><TextBlock Text="通过" FontSize="11" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Name="ScanFindingsPanel" Style="{StaticResource CardBase}" Padding="20" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="检测结果详情" Style="{StaticResource SectionTitle}"/>
                                <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl Name="ScanFindingsContainer">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FindingItem}"
                                                        BorderBrush="{StaticResource BrBorder}">
                                                    <Grid MinHeight="60">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                                                Background="{Binding BadgeBg}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                                                            <TextBlock Text="!" FontSize="14" FontWeight="Bold"
                                                                       Foreground="{Binding BadgeFg}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Border CornerRadius="999" Background="{Binding BadgeBg}" Padding="10,2">
                                                                    <TextBlock Text="{Binding SeverityLabel}" FontSize="10" Foreground="{Binding BadgeFg}" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Type}" FontSize="10" Foreground="{StaticResource BrTextSecondary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <TextBlock Text="{Binding Description}" FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Meta}" FontSize="10" Foreground="{StaticResource BrTextMuted}" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ===== REPORT ===== -->
                    <StackPanel Name="PanelReport" Visibility="Collapsed">
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="报告管理" FontSize="22" FontWeight="Bold"/><TextBlock Text="生成、导出与上传审计报告" FontSize="13" Foreground="{StaticResource BrTextSecondary}" Margin="0,4,0,0"/></StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="📄 生成新报告" Click="GenerateReport_Click"/>
                        </Grid>

                        <Border Style="{StaticResource CardBase}" Padding="24" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BrAccentDim}" CornerRadius="10" Width="48" Height="48" Margin="0,0,16,0">
                                        <TextBlock Text="📄" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <StackPanel Grid.Column="1"><TextBlock Text="本机审计报告" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Name="ReportMachineInfo" Text="未生成" FontSize="11" Foreground="{StaticResource BrTextSecondary}" Margin="0,3,0,0"/></StackPanel>
                                    <Border Grid.Column="2" Background="#34D39920" CornerRadius="999" Padding="14,5">
                                        <TextBlock Name="ReportScoreText" Text="--" FontSize="12" Foreground="{StaticResource BrGreen}"/></Border>
                                </Grid>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BrInputBg}" CornerRadius="8" Padding="12" Margin="4">
                                        <StackPanel HorizontalAlignment="Center"><TextBlock Name="ReportTotalEvents" Text="0" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Text="总事件数" FontSize="10" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{StaticResource BrInputBg}" CornerRadius="8" Padding="12" Margin="4">
                                        <StackPanel HorizontalAlignment="Center"><TextBlock Name="ReportSuspiciousCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrYellow}" HorizontalAlignment="Center"/><TextBlock Text="可疑项" FontSize="10" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{StaticResource BrInputBg}" CornerRadius="8" Padding="12" Margin="4">
                                        <StackPanel HorizontalAlignment="Center"><TextBlock Name="ReportHighCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrRed}" HorizontalAlignment="Center"/><TextBlock Text="高危项" FontSize="10" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Background="{StaticResource BrInputBg}" CornerRadius="8" Padding="12" Margin="4">
                                        <StackPanel HorizontalAlignment="Center"><TextBlock Name="ReportUploadStatus" Text="未上传" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrTextMuted}" HorizontalAlignment="Center"/><TextBlock Text="上传状态" FontSize="10" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/></StackPanel>
                                    </Border>
                                </Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButton}" Content="👁 预览报告" Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="📊 导出PDF" Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="⬇ 导出HTML" Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource SecondaryButton}" Content="🔒 加密" Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="📤 上传审核" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ===== SETTINGS ===== -->
                    <StackPanel Name="PanelSettings" Visibility="Collapsed" MaxWidth="600">
                        <TextBlock Text="设置" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="系统配置与连接管理" FontSize="13" Foreground="{StaticResource BrTextSecondary}" Margin="0,4,0,24"/>

                        <Border Style="{StaticResource CardBase}" Padding="22" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BrAccentDim}" CornerRadius="10" Width="42" Height="42" Margin="0,0,14,0">
                                        <TextBlock Text="🔌" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <StackPanel Grid.Column="1"><TextBlock Text="认证服务器" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="支持 HTTPS 和 IPv6" FontSize="11" Foreground="{StaticResource BrTextSecondary}" Margin="0,2,0,0"/></StackPanel>
                                </Grid>
                                <Border Background="{StaticResource BrInputBg}" CornerRadius="8" Padding="12,10" Margin="0,0,0,14">
                                    <Grid><Ellipse Name="ServerStatusDot" Width="7" Height="7" Fill="{StaticResource BrTextMuted}" VerticalAlignment="Center"/>
                                        <TextBlock Name="ServerStatusText" Text="服务器状态: 未连接" FontSize="12" Foreground="{StaticResource BrTextSecondary}" Margin="16,0,0,0"/></Grid>
                                </Border>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox Name="ServerUrlInput" Grid.Column="0" Style="{StaticResource InputField}" Text="https://" FontFamily="Consolas" FontSize="12" Margin="0,0,8,0" Background="{StaticResource BrInputBg}"/>
                                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="保存" Width="72" Click="SaveServerUrl_Click"/>
                                </Grid>
                                <WrapPanel Margin="0,0,0,14">
                                    <Border Background="{StaticResource BrInputBg}" CornerRadius="6" Padding="8,3" Margin="0,0,6,4" Cursor="Hand" MouseDown="ExampleUrl_Click" Tag="https://audit.example.com:8443"><TextBlock Text="HTTPS+域名" FontSize="10" Foreground="{StaticResource BrTextSecondary}"/></Border>
                                    <Border Background="{StaticResource BrInputBg}" CornerRadius="6" Padding="8,3" Margin="0,0,6,4" Cursor="Hand" MouseDown="ExampleUrl_Click" Tag="https://192.168.1.100:8000"><TextBlock Text="HTTPS+IPv4" FontSize="10" Foreground="{StaticResource BrTextSecondary}"/></Border>
                                    <Border Background="{StaticResource BrInputBg}" CornerRadius="6" Padding="8,3" Margin="0,0,6,4" Cursor="Hand" MouseDown="ExampleUrl_Click" Tag="https://[::1]:8000"><TextBlock Text="HTTPS+IPv6" FontSize="10" Foreground="{StaticResource BrTextSecondary}"/></Border>
                                    <Border Background="{StaticResource BrInputBg}" CornerRadius="6" Padding="8,3" Margin="0,0,6,4" Cursor="Hand" MouseDown="ExampleUrl_Click" Tag="http://localhost:8000"><TextBlock Text="HTTP本地" FontSize="10" Foreground="{StaticResource BrTextSecondary}"/></Border>
                                </WrapPanel>
                                <Button Style="{StaticResource SecondaryButton}" Content="🔄 测试连接" Click="TestConnection_Click" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBase}" Padding="22">
                            <StackPanel><TextBlock Text="🔒 安全信息" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"/>
                                <Border Background="{StaticResource BrInputBg}" CornerRadius="6" Padding="12,8" Margin="0,2">
                                    <Grid><TextBlock Text="License 状态" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/><TextBlock Text="已激活" FontSize="12" Foreground="{StaticResource BrGreen}" HorizontalAlignment="Right"/></Grid></Border>
                                <Border Background="{StaticResource BrInputBg}" CornerRadius="6" Padding="12,8" Margin="0,2">
                                    <Grid><TextBlock Text="硬件绑定" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/><TextBlock Name="MachineHashText" Text="未检测" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Right"/></Grid></Border>
                                <Border Background="{StaticResource BrInputBg}" CornerRadius="6" Padding="12,8" Margin="0,2">
                                    <Grid><TextBlock Text="客户端版本" FontSize="12" Foreground="{StaticResource BrTextSecondary}"/><TextBlock Text="v1.0.0" FontSize="12" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Right"/></Grid></Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
