<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ LIGHTER, PROFESSIONAL COLOR SCHEME ============ -->
    <Color x:Key="ClrBg">#1C212E</Color>
    <Color x:Key="ClrSidebar">#232838</Color>
    <Color x:Key="ClrCard">#2A3142</Color>
    <Color x:Key="ClrCardHover">#323A4E</Color>
    <Color x:Key="ClrBorder">#38405A</Color>
    <Color x:Key="ClrBorderLight">#4A5472</Color>
    <Color x:Key="ClrTextPrimary">#E4E8F0</Color>
    <Color x:Key="ClrTextSecondary">#A0A8C0</Color>
    <Color x:Key="ClrTextMuted">#6B7494</Color>
    <Color x:Key="ClrAccent">#4F8CFF</Color>
    <Color x:Key="ClrAccentDim">#2A4A8C</Color>
    <Color x:Key="ClrAccentBg">#4F8CFF12</Color>
    <Color x:Key="ClrGreen">#34D399</Color>
    <Color x:Key="ClrYellow">#FBBF24</Color>
    <Color x:Key="ClrRed">#F87171</Color>
    <Color x:Key="ClrBlue">#60A5FA</Color>
    <Color x:Key="ClrInputBg">#1C212E</Color>

    <SolidColorBrush x:Key="BrBg" Color="{StaticResource ClrBg}"/>
    <SolidColorBrush x:Key="BrSidebar" Color="{StaticResource ClrSidebar}"/>
    <SolidColorBrush x:Key="BrCard" Color="{StaticResource ClrCard}"/>
    <SolidColorBrush x:Key="BrCardHover" Color="{StaticResource ClrCardHover}"/>
    <SolidColorBrush x:Key="BrBorder" Color="{StaticResource ClrBorder}"/>
    <SolidColorBrush x:Key="BrBorderLight" Color="{StaticResource ClrBorderLight}"/>
    <SolidColorBrush x:Key="BrTextPrimary" Color="{StaticResource ClrTextPrimary}"/>
    <SolidColorBrush x:Key="BrTextSecondary" Color="{StaticResource ClrTextSecondary}"/>
    <SolidColorBrush x:Key="BrTextMuted" Color="{StaticResource ClrTextMuted}"/>
    <SolidColorBrush x:Key="BrAccent" Color="{StaticResource ClrAccent}"/>
    <SolidColorBrush x:Key="BrAccentDim" Color="{StaticResource ClrAccentDim}"/>
    <SolidColorBrush x:Key="BrAccentBg" Color="{StaticResource ClrAccentBg}"/>
    <SolidColorBrush x:Key="BrGreen" Color="{StaticResource ClrGreen}"/>
    <SolidColorBrush x:Key="BrYellow" Color="{StaticResource ClrYellow}"/>
    <SolidColorBrush x:Key="BrRed" Color="{StaticResource ClrRed}"/>
    <SolidColorBrush x:Key="BrBlue" Color="{StaticResource ClrBlue}"/>
    <SolidColorBrush x:Key="BrInputBg" Color="{StaticResource ClrInputBg}"/>

    <!-- ============ CARD STYLE ============ -->
    <Style x:Key="CardBase" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ============ NAV ITEM ============ -->
    <Style x:Key="NavItem" TargetType="Border">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Margin" Value="4,1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ============ SECTION TITLE ============ -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>

    <!-- ============ STAT TEXT ============ -->
    <Style x:Key="StatValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
    </Style>

    <Style x:Key="StatLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextSecondary}"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <!-- ============ BADGES ============ -->
    <Style x:Key="BadgeGreen" TargetType="Border">
        <Setter Property="Background" Value="#34D39920"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,3"/>
    </Style>
    <Style x:Key="BadgeYellow" TargetType="Border">
        <Setter Property="Background" Value="#FBBF2420"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,3"/>
    </Style>
    <Style x:Key="BadgeRed" TargetType="Border">
        <Setter Property="Background" Value="#F8717120"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,3"/>
    </Style>

    <!-- ============ BUTTONS ============ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrAccent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Padding" Value="20,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="9"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#6BA0FF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource BrBorder}"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource BrRed}"/>
    </Style>

    <!-- ============ TEXTBOX ============ -->
    <Style x:Key="InputField" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrInputBg}"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="{StaticResource BrAccent}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrBorderLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PasswordField" TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource BrInputBg}"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ EVENT ITEM ============ -->
    <Style x:Key="EventItem" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrInputBg}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,3"/>
    </Style>

    <!-- ============ FINDING ITEM ============ -->
    <Style x:Key="FindingItem" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrInputBg}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Margin" Value="0,4"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
</ResourceDictionary>
